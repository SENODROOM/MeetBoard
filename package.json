{
    "name": "meet-board",
    "version": "1.0.0",
    "description": "Real-time communication platform",
    "private": true,
    "workspaces": [
        "backend",
        "frontend"
    ],
    "scripts": {
        "dev": "npm run dev:all",
        "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "cd backend && npm run setup",
        "dev:frontend": "cd frontend && npm run start:dev",
        "start": "npm run start:all",
        "start:all": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
        "start:backend": "cd backend && npm run setup",
        "start:frontend": "cd frontend && npm run start:dev",
        "docker:start": "docker-compose up -d postgres mongodb redis minio",
        "docker:stop": "docker-compose down",
        "docker:logs": "docker-compose logs -f",
        "setup": "npm install && cd backend && npm install && cd ../frontend && npm install",
        "clean": "docker-compose down -v && rm -rf backend/node_modules frontend/node_modules node_modules"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}